<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">
	<Frame name="BPCSimplePanelTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="layoutType" value="SimplePanelTemplate" type="string"/>
		</KeyValues>
		<Size x="338" y="424"/>
		<Layers>
			<Layer level="BACKGROUND" textureSubLevel="-6">
				<Texture name="$parentBg" file="Interface\FrameGeneral\UI-Background-Rock" horizTile="true" vertTile="true" parentKey="Bg">
					<Anchors>
						<Anchor point="TOPLEFT" x="0" y="-6"/>
						<Anchor point="BOTTOMRIGHT" x="-2" y="3"/>
					</Anchors>
				</Texture>
			</Layer>
		</Layers>
		<Frames>
			<Frame parentKey="Inset" inherits="InsetFrameTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" x="4" y="-26"/>
					<Anchor point="BOTTOMRIGHT" x="-6" y="26"/>
				</Anchors>
			</Frame>
			<Frame parentKey="NineSlice" inherits="NineSlicePanelTemplate"/>
		</Frames>
	</Frame>

	<Frame name="BPCPetsDialogFrame" parent="UIParent" inherits="BPCSimplePanelTemplate" hidden="true">
		<Anchors>
			<Anchor point="TOP" x="0" y="-100"/>
		</Anchors>
		<Layers>
			<Layer level="ARTWORK">
				<FontString parentKey="Header" inherits="GameFontNormal" justifyH="LEFT">
					<Anchors>
						<Anchor point="TOPLEFT" x="16" y="-40"/>
					</Anchors>
				</FontString>
				<Texture parentKey="Row1Icon" hidden="true">
					<Size x="32" y="32"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="12" y="-60"/>
					</Anchors>
				</Texture>
				<FontString parentKey="Row1Label" inherits="GameFontNormal" justifyH="LEFT" hidden="true">
					<Anchors>
						<Anchor point="LEFT" relativeKey="$parent.Row1Icon" x="40" y="0"/>
					</Anchors>
				</FontString>
				<Texture parentKey="Row2Icon" hidden="true">
					<Size x="32" y="32"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="12" y="-96"/>
					</Anchors>
				</Texture>
				<FontString parentKey="Row2Label" inherits="GameFontNormal" justifyH="LEFT" hidden="true">
					<Anchors>
						<Anchor point="LEFT" relativeKey="$parent.Row2Icon" x="40" y="0"/>
					</Anchors>
				</FontString>
				<Texture parentKey="Row3Icon" hidden="true">
					<Size x="32" y="32"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="12" y="-132"/>
					</Anchors>
				</Texture>
				<FontString parentKey="Row3Label" inherits="GameFontNormal" justifyH="LEFT" hidden="true">
					<Anchors>
						<Anchor point="LEFT" relativeKey="$parent.Row3Icon" x="40" y="0"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
	</Frame>

	<Script file="CaptureModule.lua"/>
</Ui>
