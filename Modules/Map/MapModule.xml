<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">
    <Frame name="BPetCompletionistWorldMapPinTemplate" hidden="true" enableMouse="true" mixin="BattlePetCompletionistWorldMapPinMixin" virtual="true">
        <Layers>
            <Layer level="ARTWORK">
                <Texture parentKey="Icon" setAllPoints="true">
                </Texture>
                <MaskTexture file="Interface\CharacterFrame\TempPortraitAlphaMask" hWrapMode="CLAMPTOBLACKADDITIVE" vWrapMode="CLAMPTOBLACKADDITIVE">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.Icon" x="1.2" y="-1.2"/>
                        <Anchor point="BOTTOMRIGHT" relativeKey="$parent.Icon" x="-1.2" y="1.2"/>
                    </Anchors>
                    <MaskedTextures>
                        <MaskedTexture childKey="Icon"/>
                    </MaskedTextures>
                </MaskTexture>
                <Texture parentKey="IconBorder" atlas="Neutraltrait-border-selected">
                    <Anchors>
                        <Anchor point="CENTER"/>
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>
    </Frame>

    <Script file="MapModule.lua"/>
    <Script file="MapTooltip.lua"/>

    <Frame name="BPCMapTooltip" parent="UIParent" frameStrata="TOOLTIP" hidden="true" inherits="BackdropTemplate">
        <KeyValues>
            <KeyValue key="backdropInfo" value="BPC_MAP_TOOLTIP_BACKDROP" type="global"/>
            <KeyValue key="backdropColor" value="BLACK_FONT_COLOR" type="global"/>
            <KeyValue key="backdropColorAlpha" value="0.9" type="number"/>
        </KeyValues>
        <Layers>
            <Layer level="ARTWORK">
                <FontString parentKey="Header" justifyH="LEFT" wordWrap="false">
                    <Anchors>
                        <Anchor point="TOPLEFT" x="8" y="-8"/>
                    </Anchors>
                </FontString>
                <FontString parentKey="Collected" inherits="GameFontNormal" justifyH="LEFT" wordWrap="false" hidden="true">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.Header" relativePoint="BOTTOMLEFT" y="-2"/>
                    </Anchors>
                </FontString>
                <FontString parentKey="Source" inherits="GameFontNormal" justifyH="LEFT" wordWrap="false">
                </FontString>
            </Layer>
        </Layers>
    </Frame>
</Ui>
